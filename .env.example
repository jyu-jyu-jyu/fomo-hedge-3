# OAuth credentials — copy to .env and fill in your values

# Eventbrite: https://www.eventbrite.com/platform/api/apps/
EVENTBRITE_CLIENT_ID=
EVENTBRITE_CLIENT_SECRET=

# Microsoft Azure App Registration: https://portal.azure.com/#view/Microsoft_AAD_RegisteredApps
# Required scopes: Calendars.Read, User.Read, offline_access
OUTLOOK_CLIENT_ID=
OUTLOOK_CLIENT_SECRET=

# Base URL of your running server (used to build OAuth redirect URIs)
REDIRECT_BASE_URL=http://localhost:5000
